  </link>

  <!-- DIP curl joint (MIMIC - follows MCP) -->
  <!-- UPDATE multiplier=2.85 after physical measurement! -->
  <joint name="ring_curl_dip" type="revolute">
    <parent link="ring_mid"/>
    <child link="ring_tip"/>
    <origin xyz="0.004166 -0.010332 -0.030832" rpy="0 0 0"/>
    <axis xyz="-0.9874 0.0000 -0.1582"/>
    <limit lower="0.0" upper="1.55" effort="1.0" velocity="3.0"/>
    <mimic joint="ring_curl" multiplier="1.96" offset="0.0"/>
