    <child link="middle_knuckle"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="-1.0000 -0.0000 0.0008"/>
    <limit lower="0.0" upper="1.09" effort="1.0" velocity="3.0"/>
  </joint>

  <link name="middle_knuckle">
    <visual>
      <origin xyz="-0.023834 0.004604 0.000670" rpy="0 0 0"/>
