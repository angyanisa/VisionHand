<?xml version="1.0"?>
<robot name="nanohand">

  <!-- NanoHand 10-DOF URDF with Mimic Joints -->
  <!-- 3 curl joints per finger: MCP (controlled) + PIP (mimic) + DIP (mimic) -->
  <!-- UPDATE mimic multipliers after physical measurement with protractor! -->

  <!-- ===== PALM ===== -->
  <link name="palm">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hands/urdf/nano/meshes/palm.stl"/></geometry>
      <material name="palm_mat"><color rgba="0.9 0.75 0.2 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="package://hands/urdf/nano/meshes/palm.stl"/></geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- Visualization / RViz convenience frame.
       Keep palm as the kinematic root so existing PyBullet joint indices do not change.
       RViz can use `base` as the fixed frame; the 180° X rotation flips the hand upright
       relative to the imported CAD mesh orientation. -->
  <link name="base"/>
  <joint name="palm_to_base" type="fixed">
    <parent link="palm"/>
    <child link="base"/>
    <origin xyz="0 0 0" rpy="3.141592653589793 0 0"/>
  </joint>


  <!-- ===== PINKY (wiggle + 3 curl joints) ===== -->
  <!-- Wiggle joint at MCP -->
  <joint name="pinky_wiggle" type="revolute">
    <parent link="palm"/>
    <child link="pinky_base"/>
    <origin xyz="0.057168 -0.015536 0.018012" rpy="0 0 0"/>
    <axis xyz="0.0000 1.0000 0.0000"/>
    <limit lower="-0.17" upper="0.17" effort="1.0" velocity="3.0"/>
  </joint>

  <link name="pinky_base">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-8" iyy="1e-8" izz="1e-8" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- MCP curl joint (CONTROLLED by servo) -->
  <joint name="pinky_curl" type="revolute">
    <parent link="pinky_base"/>
    <child link="pinky_knuckle"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="-0.9606 0.0000 -0.2778"/>
    <limit lower="0.0" upper="0.97" effort="1.0" velocity="3.0"/>
  </joint>

  <link name="pinky_knuckle">
    <visual>
      <origin xyz="-0.057168 0.015536 -0.018012" rpy="0 0 0"/>
      <geometry><mesh filename="package://hands/urdf/nano/meshes/Pinky_knuckle_section.stl"/></geometry>
      <material name="pinky_knuckle_mat"><color rgba="0.85 0.7 0.15 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="-0.057168 0.015536 -0.018012" rpy="0 0 0"/>
      <geometry><mesh filename="package://hands/urdf/nano/meshes/Pinky_knuckle_section.stl"/></geometry>
    </collision>
    <inertial>
      <mass value="0.005"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- PIP curl joint (MIMIC - follows MCP) -->
  <!-- UPDATE multiplier=2.92 after physical measurement! -->
  <joint name="pinky_curl_pip" type="revolute">
    <parent link="pinky_knuckle"/>
    <child link="pinky_mid"/>
    <origin xyz="0.013926 -0.006788 -0.037303" rpy="0 0 0"/>
    <axis xyz="-0.9606 0.0000 -0.2778"/>
    <limit lower="0.0" upper="1.41" effort="1.0" velocity="3.0"/>
    <mimic joint="pinky_curl" multiplier="2" offset="0.0"/>
  </joint>

  <link name="pinky_mid">
    <visual>
      <origin xyz="-0.071094 0.022325 0.019291" rpy="0 0 0"/>
      <geometry><mesh filename="package://hands/urdf/nano/meshes/Pinky_mid_section.stl"/></geometry>
      <material name="pinky_mid_mat"><color rgba="0.8 0.65 0.12 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="-0.071094 0.022325 0.019291" rpy="0 0 0"/>
      <geometry><mesh filename="package://hands/urdf/nano/meshes/Pinky_mid_section.stl"/></geometry>
    </collision>
    <inertial>
      <mass value="0.004"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- DIP curl joint (MIMIC - follows MCP) -->
  <!-- UPDATE multiplier=3.94 after physical measurement! -->
  <joint name="pinky_curl_dip" type="revolute">
    <parent link="pinky_mid"/>
    <child link="pinky_tip"/>
    <origin xyz="0.006182 -0.006283 -0.028732" rpy="0 0 0"/>
    <axis xyz="-0.9606 0.0000 -0.2778"/>
    <limit lower="0.0" upper="1.64" effort="1.0" velocity="3.0"/>
    <mimic joint="pinky_curl" multiplier="2.23" offset="0.0"/>
  </joint>

  <link name="pinky_tip">
    <visual>
      <origin xyz="-0.077276 0.028608 0.048023" rpy="0 0 0"/>
      <geometry><mesh filename="package://hands/urdf/nano/meshes/Pinky_tip_section.stl"/></geometry>
      <material name="pinky_tip_mat"><color rgba="0.75 0.6 0.1 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="-0.077276 0.028608 0.048023" rpy="0 0 0"/>
      <geometry><mesh filename="package://hands/urdf/nano/meshes/Pinky_tip_section.stl"/></geometry>
    </collision>
    <inertial>
      <mass value="0.003"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ===== RING (wiggle + 3 curl joints) ===== -->
  <!-- Wiggle joint at MCP -->
  <joint name="ring_wiggle" type="revolute">
    <parent link="palm"/>
    <child link="ring_base"/>
    <origin xyz="0.041630 -0.009469 0.007289" rpy="0 0 0"/>
    <axis xyz="0.0000 1.0000 0.0000"/>
    <limit lower="-0.2" upper="0.13" effort="1.0" velocity="3.0"/>
  </joint>

  <link name="ring_base">
    <inertial>
      <mass value="0.001"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-8" iyy="1e-8" izz="1e-8" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- MCP curl joint (CONTROLLED by servo) -->
  <joint name="ring_curl" type="revolute">
    <parent link="ring_base"/>
    <child link="ring_knuckle"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="-0.9874 0.0000 -0.1582"/>
    <limit lower="0.0" upper="0.83" effort="1.0" velocity="3.0"/>
  </joint>

  <link name="ring_knuckle">
    <visual>
      <origin xyz="-0.041630 0.009469 -0.007289" rpy="0 0 0"/>
      <geometry><mesh filename="package://hands/urdf/nano/meshes/Ring_knuckle_section.stl"/></geometry>
      <material name="ring_knuckle_mat"><color rgba="0.85 0.7 0.15 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="-0.041630 0.009469 -0.007289" rpy="0 0 0"/>
      <geometry><mesh filename="package://hands/urdf/nano/meshes/Ring_knuckle_section.stl"/></geometry>
    </collision>
    <inertial>
      <mass value="0.005"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- PIP curl joint (MIMIC - follows MCP) -->
  <!-- UPDATE multiplier=2.31 after physical measurement! -->
  <joint name="ring_curl_pip" type="revolute">
    <parent link="ring_knuckle"/>
    <child link="ring_mid"/>
    <origin xyz="0.008798 -0.005417 -0.045473" rpy="0 0 0"/>
    <axis xyz="-0.9874 0.0000 -0.1582"/>
    <limit lower="0.0" upper="1.29" effort="1.0" velocity="3.0"/>
    <mimic joint="ring_curl" multiplier="1.5" offset="0.0"/>
  </joint>

  <link name="ring_mid">
    <visual>
      <origin xyz="-0.050428 0.014886 0.038184" rpy="0 0 0"/>
      <geometry><mesh filename="package://hands/urdf/nano/meshes/Ring_mid_section.stl"/></geometry>
      <material name="ring_mid_mat"><color rgba="0.8 0.65 0.12 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="-0.050428 0.014886 0.038184" rpy="0 0 0"/>
      <geometry><mesh filename="package://hands/urdf/nano/meshes/Ring_mid_section.stl"/></geometry>
