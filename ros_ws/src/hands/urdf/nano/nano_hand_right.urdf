      <material name="middle_knuckle_mat"><color rgba="0.85 0.7 0.15 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="-0.023834 0.004604 0.000670" rpy="0 0 0"/>
      <geometry><mesh filename="package://hands/urdf/nano/meshes/Middle_knuckle_section.stl"/></geometry>
    </collision>
    <inertial>
      <mass value="0.005"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- PIP curl joint (MIMIC - follows MCP) -->
  <!-- UPDATE multiplier=2.2 after physical measurement! -->
  <joint name="middle_curl_pip" type="revolute">
    <parent link="middle_knuckle"/>
    <child link="middle_mid"/>
    <origin xyz="-0.000673 -0.000639 -0.047688" rpy="0 0 0"/>
    <axis xyz="-1.0000 -0.0000 0.0008"/>
    <limit lower="0.0" upper="1.65" effort="1.0" velocity="3.0"/>
    <mimic joint="middle_curl" multiplier="2" offset="0.0"/>
  </joint>

  <link name="middle_mid">
    <visual>
      <origin xyz="-0.023161 0.005243 0.048359" rpy="0 0 0"/>
      <geometry><mesh filename="package://hands/urdf/nano/meshes/Middle_mid_section.stl"/></geometry>
      <material name="middle_mid_mat"><color rgba="0.8 0.65 0.12 1.0"/></material>
