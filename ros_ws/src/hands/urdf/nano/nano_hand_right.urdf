  <!-- DIP curl joint (MIMIC - follows MCP) -->
  <!-- UPDATE multiplier=0.54 after physical measurement! -->
  <joint name="thumb_curl_dip" type="revolute">
    <parent link="thumb_mid"/>
    <child link="thumb_tip"/>
    <origin xyz="-0.001268 -0.024596 -0.029024" rpy="0 0 0"/>
    <axis xyz="0.9943 0.0000 -0.1066"/>
    <limit lower="0.0" upper="1.65" effort="1.0" velocity="3.0"/>
    <mimic joint="thumb_curl" multiplier="1" offset="0.0"/>
  </joint>

  <link name="thumb_tip">
    <visual>
      <origin xyz="-0.009105 0.099274 -0.010535" rpy="0 0 0"/>
      <geometry><mesh filename="package://hands/urdf/nano/meshes/Thumb_tip_section.stl"/></geometry>
      <material name="thumb_tip_mat"><color rgba="0.75 0.6 0.1 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="-0.009105 0.099274 -0.010535" rpy="0 0 0"/>
      <geometry><mesh filename="package://hands/urdf/nano/meshes/Thumb_tip_section.stl"/></geometry>
    </collision>
    <inertial>
      <mass value="0.003"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="1e-6" iyy="1e-6" izz="1e-6" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

          <!-- ===== FIXED FINGERTIP EXTENSIONS =====
       Added so that IK targets the physical fingertip (end of distal phalanx)
       rather than the DIP revolute joint pivot.  Offsets derived from the
       bounding-box extrema of each tip-section STL mesh (in palm global space)
       minus the DIP joint world position.  Placed at the end of the URDF so
       existing PyBullet joint indices are unchanged. -->

  <link name="pinky_fingertip"/>
  <joint name="pinky_fingertip_joint" type="fixed">
    <parent link="pinky_tip"/>
    <child link="pinky_fingertip"/>
    <origin xyz="0.002 -0.003 -0.027" rpy="0 0 0"/>
  </joint>

  <link name="ring_fingertip"/>
  <joint name="ring_fingertip_joint" type="fixed">
    <parent link="ring_tip"/>
    <child link="ring_fingertip"/>
    <origin xyz="0.000 -0.007 -0.027" rpy="0 0 0"/>
  </joint>

  <link name="middle_fingertip"/>
  <joint name="middle_fingertip_joint" type="fixed">
    <parent link="middle_tip"/>
    <child link="middle_fingertip"/>
    <origin xyz="0.000 -0.001 -0.031" rpy="0 0 0"/>
  </joint>

  <link name="index_fingertip"/>
  <joint name="index_fingertip_joint" type="fixed">
    <parent link="index_tip"/>
    <child link="index_fingertip"/>
    <origin xyz="-0.001 -0.002 -0.030" rpy="0 0 0"/>
  </joint>

  <link name="thumb_fingertip"/>
  <joint name="thumb_fingertip_joint" type="fixed">
    <parent link="thumb_tip"/>
    <child link="thumb_fingertip"/>
    <origin xyz="0.000 -0.023 -0.016" rpy="0 0 0"/>
  </joint>
  
</robot>
