  <link name="ring_tip">
    <visual>
      <origin xyz="-0.054594 0.025218 0.069016" rpy="0 0 0"/>
      <geometry><mesh filename="package://hands/urdf/nano/meshes/Ring_tip_section.stl"/></geometry>
      <material name="ring_tip_mat"><color rgba="0.75 0.6 0.1 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="-0.054594 0.025218 0.069016" rpy="0 0 0"/>
      <geometry><mesh filename="package://hands/urdf/nano/meshes/Ring_tip_section.stl"/></geometry>
